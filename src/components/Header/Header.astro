---
import CloseIcon from "../CloseIcon/CloseIcon.astro";
import CurlArrow from "../CurlArrow/CurlArrow.astro";
import HeaderItem from "../HeaderItem/HeaderItem.astro";
import HeaderMenuItemMobile from "../HeaderItemMobile/HeaderItemMobile.astro";

const open = false;
const pageModules = import.meta.glob("../../pages/**/*.{astro,md,mdx}", { eager: true });
const pageEntries = Object.entries(pageModules) as [string, Record<string, any>][];

interface MenuItem {
  title: string;
  href: string;
  parent?: string;
}

function deriveUrl(filePath: string): string {
  return filePath
    .replace(/^.*\/pages/, "")
    .replace(/\.(astro|md|mdx)$/, "")
    .replace(/\/index$/, "/");
}

function extractMenuItems(entries: [string, Record<string, any>][]): MenuItem[] {
  const blackList = ["impressum", "kontakt"];

  return entries
    .map(([filePath, mod]) => {
      if (blackList.some((item) => filePath.includes(item))) {
        return null;
      }

      const url = (mod.url as string | undefined) ?? deriveUrl(filePath);

      if (url) {
        const frontmatter = mod.frontmatter as Record<string, string> | undefined;
        return {
          title: frontmatter?.title || getDefaultTitle(url),
          href: url,
          parent: frontmatter?.parent,
        } as MenuItem;
      }
      return null;
    })
    .filter((item): item is MenuItem => item !== null);
}

function getDefaultTitle(url: string): string {
  const path = url.replace(/^\/|\/$/g, "");

  if (path === "") return "Home";

  return (
    path
      .split("/")
      .pop()
      ?.split("-")
      .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
      .join(" ") || "Page"
  );
}

const menuItems = extractMenuItems(pageEntries);
---

<script>
  // I know this is not nice to do, but I do not care
  const burger = document.querySelector(".burger")!;
  const menu = document.querySelector(".menu-mobile")!;
  const arrow = document.querySelector(".arrow")!;
  const close = document.querySelector(".close")!;

  burger.addEventListener("click", () => {
    menu.classList.add("open");
    arrow.classList.add("open");
    burger.classList.add("open");
    close.classList.add("open");
  });

  close.addEventListener("click", () => {
    menu.classList.remove("open");
    arrow.classList.remove("open");
    burger.classList.remove("open");
    close.classList.remove("open");
  });
</script>

<!-- Navigation Header -->
<nav class="menu-desktop">
  <a href="/">
    <img src="/images/kila_header1.png" alt="Kinderladen Logo" />
  </a>
  <ul>
    {
      menuItems.map((item) => (
        <li>
          <HeaderItem text={item.title} href={item.href} />
        </li>
      ))
    }
  </ul>
  <span class="burger-container">
    <img
      class:list={["burger", { open }]}
      src="/icons/burger.svg"
      alt="Burger Menu"
    />
    <CloseIcon class:list={["close", { open }]} />
    <CurlArrow class:list={["arrow", { open }]} />
  </span>
</nav>

<nav class:list={["menu-mobile", { open }]}>
  <!-- <BackgroundMenu /> -->
  <ul>
    {
      menuItems.map((item) => (
        <li>
          <HeaderMenuItemMobile text={item.title} href={item.href} />
        </li>
      ))
    }
    <li>
      <HeaderMenuItemMobile text="Kontakt" href="/kontakt" />
    </li>
  </ul>
</nav>

<style>
  .menu-desktop {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .menu-desktop ul {
    gap: 1rem;
    list-style: none;
    display: none;
    position: relative;
    margin-left: auto;

    @media (min-width: 768px) {
      display: flex;
    }
  }

  .burger {
    @media (min-width: 768px) {
      display: none;
    }
  }

  .burger.open {
    display: none;
  }

  :global(html:has(.burger.open)) {
    overflow: hidden;
  }

  .menu-mobile {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 85%;
    width: 95%;
    clip-path: polygon(
      11% 4.94%,
      90.04% 3.11%,
      93.79% 2.8%,
      97.25% 3.29%,
      99.88% 4.33%,
      100.46% 5.74%,
      100.33% 7.04%,
      99.55% 19.55%,
      99.55% 19.55%,
      98.59% 52.34%,
      94.3% 88.66%,
      92.72% 91.18%,
      90.67% 93.48%,
      88.1% 94.48%,
      51.07% 94.58%,
      12.59% 92.49%,
      9.42% 92.49%,
      6.93% 91.62%,
      4.26% 90.18%,
      2.35% 88.02%,
      0.93% 59.07%,
      1.97% 29.46%,
      3.75% 12.08%,
      5.33% 8.8%,
      7.76% 6.63%
    );
    background-color: var(--kila-accent);
  }

  .menu-mobile.open {
    position: fixed;
    margin: 0 auto;
    left: 50%;
    z-index: 5;
    top: 6rem;

    display: flex;
    transform: translate(-50%);
  }

  .menu-mobile ul {
    text-align: center;
    width: 65%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    height: 80%;
    list-style: none;
    padding: 0;
    font-weight: 500;
  }

  .menu-mobile ul li {
    height: 34px;
  }

  .menu-desktop {
    position: relative;
  }

  .burger-container {
    position: relative;
  }

  .arrow {
    position: absolute;
    display: none;
    bottom: 0;
    left: -138px;
    bottom: -71px;
  }

  .close {
    display: none;
    position: absolute;
    top: -23px;
    left: -47px;
  }

  .arrow.open {
    display: block;
    animation: gelatine 1s alternate;
  }

  .close.open {
    display: block;
  }
</style>
